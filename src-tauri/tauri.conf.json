{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AI就活",
  "version": "0.1.1",
  "identifier": "com.aisyuukatsu.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "AI就活",
        "width": 1280,
        "height": 840,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Productivity",
    "shortDescription": "AI就活 — 就職活動管理デスクトップアプリ",
    "longDescription": "AI就活 は、就職活動の情報整理・記録・管理を支援するローカルファーストのデスクトップアプリケーションです。",
    "createUpdaterArtifacts": true,
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDU0QkM4MjlGODQ4MTVCODYKUldTR1c0R0VuNEs4Vk9GMWt6R1kramMyckFNd2N3TFFHVHFpS2ppVWtOUkpIRXNYTFUwSHJKV1UK",
      "endpoints": [
        "https://github.com/yamauchiyuhei/AIsyuukatsu/releases/latest/download/latest.json"
      ]
    },
    "deep-link": {
      "desktop": {
        "schemes": ["aisyuukatsu"]
      }
    }
  }
}
